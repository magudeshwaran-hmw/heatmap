# Zensar Intelligence Configuration
# ==========================================
# Copy this file to .env and fill in your values
# cp .env.example .env
# ==========================================

# PostgreSQL Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=skillmatrix
DB_USER=postgres
DB_PASSWORD=your_postgres_password_here

# Server port
PORT=3001

# --- AI / LLM CONFIGURATION ---
# Options: "ollama" (local) or "gemini" (cloud)
LLM_PROVIDER=ollama
LLM_MODEL=deepseek-v3.1:671b-cloud

# Google Gemini API Key (free at https://aistudio.google.com/app/apikey)
# Leave empty to use local Ollama instead
CLOUD_API_KEY=

# Local Ollama model fallback
LOCAL_MODEL=deepseek-v3.1:671b-cloud
