# ==========================================
#  ZenSkill Navigator — Environment Config
# ==========================================
#  Copy this file to .env and fill in your values:
#    Windows:   copy .env.example .env
#    Mac/Linux: cp .env.example .env
# ==========================================

# ─── DATABASE (PostgreSQL) ────────────────
# Standard local install: only DB_PASSWORD needs changing.
DB_HOST=localhost
DB_PORT=5432
DB_NAME=skillmatrix
DB_USER=postgres
DB_PASSWORD=YOUR_POSTGRES_PASSWORD
# Set to true only if your Postgres requires SSL (most local installs do not)
DB_SSL=false

# ─── SERVER ───────────────────────────────
# Backend API port (internal — do not change)
PORT=3001

# Single-port gateway: one URL serves frontend + backend + Ollama.
# Keep these as-is for local dev and tunnel sharing.
GATEWAY_PORT=8080
VITE_GATEWAY_PORT=8080
VITE_SINGLE_PORT=true

# Used only when NOT in single-port mode (separate frontend/backend):
VITE_API_URL=http://localhost:3001/api

# ─── SECURITY (optional) ──────────────────
# Leave blank to use built-in dev defaults. Set strong random values
# for any shared/production deployment.
JWT_SECRET=
ENCRYPTION_KEY=

# ─── AI / LLM (optional) ──────────────────
# Provider: "ollama" (local, free) or "gemini" (cloud)
LLM_PROVIDER=ollama
LLM_MODEL=llama3
LOCAL_MODEL=llama3
# Local Ollama endpoint (install from https://ollama.ai, then `ollama pull llama3`)
VITE_OLLAMA_URL=http://127.0.0.1:11434
# Google Gemini API key — only needed if LLM_PROVIDER=gemini
# Get a free key at https://aistudio.google.com/app/apikey
CLOUD_API_KEY=

# ─── EXTERNAL APIS (optional) ─────────────
# GitHub token is OPTIONAL.
# ZenCode (GitHub Intelligence) works without it using unauthenticated requests
# (60/hour limit, analyzes the top 15 repos).
# Add a token ONLY if you want higher rate limits (5000/hour, analyzes all repos).
# Get one from https://github.com/settings/tokens
# (classic token, no scopes needed for public data).
GITHUB_TOKEN=

# Judge0 (code execution in coding assessments) via RapidAPI
# Get a key at https://rapidapi.com/judge0-official
JUDGE0_API_KEY=
JUDGE0_API_URL=https://judge0-ce.p.rapidapi.com

# ─── TUNNELING (optional) ─────────────────
# Only needed for `npm run forward` (ngrok). forward:cf / forward:lt need no token.
# Get a free token at https://dashboard.ngrok.com/get-started/your-authtoken
NGROK_AUTHTOKEN=
